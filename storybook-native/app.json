{
  "expo": {
    "name": "Pearpass Storybook",
    "slug": "pearpass-storybook-native",
    "version": "0.0.1",
    "orientation": "portrait",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.pearpass.storybook"
    },
    "android": {
      "package": "com.pearpass.storybook"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "assets/fonts/humble-nostalgia.otf",
            "assets/fonts/inter.ttf"
          ]
        }
      ]
    ]
  }
}
